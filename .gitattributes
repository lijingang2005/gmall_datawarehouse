# 自动检测文本文件并规范化换行符
* text=auto

# Shell 脚本统一使用 LF 换行符
*.sh        text eol=lf

# 配置文件使用 LF
*.conf      text eol=lf
*.properties text eol=lf
*.xml       text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf

# SQL 文件使用 LF
*.sql       text eol=lf

# Markdown 文件使用 LF
*.md        text eol=lf

# 二进制文件（不转换）
*.jar       binary
*.tar       binary
*.gz        binary
*.zip       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary

# Windows 批处理脚本使用 CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf
